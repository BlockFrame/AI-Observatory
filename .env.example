# Native Gemini LLM provider (Google AI Studio)
GEMINI_API_KEY=your-google-ai-studio-key

# Optional hero image provider. This may use the same Google API key when the
# selected image model has quota.
GOOGLE_API_KEY=your-google-ai-studio-key

# Optional source integrations
TWITTERAPI_IO_KEY=
SCRAPECREATORS_API_KEY=
GITHUB_TOKEN=

# Collection schedule (cron format)
COLLECTION_SCHEDULE=0 6 * * *
LOOKBACK_HOURS=24
TZ=America/New_York

# Legacy / alternative providers (only needed when selected in providers.yaml)
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
OPENROUTER_API_KEY=
