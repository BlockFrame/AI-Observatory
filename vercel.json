{
  "projectSettings": {
    "sourceFilesOutsideRootDirectory": true,
    "nodeVersion": "20.x"
  },
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "web",
  "installCommand": "npm install",
  "env": {
    "VERCEL": "true"
  },
  "routes": [
    {
      "src": "/data/.*\\.json$",
      "headers": {
        "Cache-Control": "public, max-age=3600",
        "Content-Type": "application/json"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800"
        },
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/ai-index.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
