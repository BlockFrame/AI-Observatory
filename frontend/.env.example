# Frontend Environment Variables Example
# Copy this to frontend/.env.local for development
# For production, set these in Vercel Project Settings → Environment Variables

# Backend API URL (where the Python pipeline outputs JSON files)
# If using GitHub Pages or CDN for backend outputs, point here:
VITE_API_URL=http://localhost:8000

# Alternative: If backend outputs are on the same domain (e.g., /api/data/)
# VITE_API_URL=

# App name (displayed in UI)
VITE_APP_NAME=AI News Aggregator

# Optional: Analytics endpoint
# VITE_ANALYTICS_URL=https://analytics.example.com

# Optional: Sentry error tracking
# VITE_SENTRY_DSN=https://key@sentry.io/project-id
